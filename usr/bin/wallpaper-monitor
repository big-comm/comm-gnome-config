#!/usr/bin/env python3

"""
BigCommunity Wallpaper Monitor Service
This script monitors the user's desktop wallpaper and updates the GDM login screen
when the wallpaper changes. Optimized for BigCommunity distro.
"""

import os
import sys
import time
import subprocess
import logging
import signal
import pwd
import select

# Configure logging
logging.basicConfig(
    filename='/var/log/wallpaper-monitor.log',
    level=logging.INFO,
    format='%(asctime)s - BigCommunity - %(levelname)s - %(message)s'
)

# Global variable for execution control
running = True

# Lock file to coordinate with other scripts
LOCK_FILE = "/var/lock/gdm-theme-operations.lock"
BACKGROUND_PATH = "/org/gnome/desktop/background/"
BACKGROUND_KEYS = [
    "/org/gnome/desktop/background/picture-uri",
    "/org/gnome/desktop/background/picture-uri-dark",
]
MONITOR_CHECK_INTERVAL = 60
SESSION_CHECK_INTERVAL = 10
POLL_FALLBACK_INTERVAL = 10

_last_monitor_check = 0
_last_should_monitor = None

def signal_handler(sig, frame):
    """Signal handler for safe shutdown"""
    global running
    logging.info(f"Signal received: {sig}")
    running = False

def is_pid_running(pid):
    """Return True when a lock owner still exists."""
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    except Exception:
        return False

def remove_stale_lock():
    """Remove stale lock files left by interrupted updates."""
    try:
        with open(LOCK_FILE, "r") as f:
            lock_pid = int(f.read().strip() or "0")
        if lock_pid and is_pid_running(lock_pid):
            return False
        os.unlink(LOCK_FILE)
        logging.warning("Removed stale GDM wallpaper lock")
        return True
    except FileNotFoundError:
        return True
    except Exception as e:
        logging.warning(f"Could not inspect GDM wallpaper lock: {e}")
        return False

def acquire_lock(timeout=10):
    """Acquire lock to coordinate with other scripts"""
    deadline = time.monotonic() + timeout
    while running and time.monotonic() <= deadline:
        try:
            lock_fd = os.open(LOCK_FILE, os.O_CREAT | os.O_WRONLY | os.O_EXCL)
            os.write(lock_fd, str(os.getpid()).encode())
            return lock_fd
        except FileExistsError:
            remove_stale_lock()
            time.sleep(1)
        except OSError as e:
            logging.warning(f"Could not acquire GDM wallpaper lock: {e}")
            time.sleep(1)
    return None

def release_lock(lock_fd):
    """Release the lock"""
    try:
        if lock_fd is not None:
            os.close(lock_fd)
            os.unlink(LOCK_FILE)
    except Exception:
        pass

def run_command(cmd, shell=False, env=None, timeout=15):
    """Execute command and return output or None on error"""
    try:
        if shell:
            result = subprocess.run(
                cmd,
                shell=True,
                check=True,
                text=True,
                capture_output=True,
                env=env,
                timeout=timeout,
            )
        else:
            result = subprocess.run(
                cmd,
                check=True,
                text=True,
                capture_output=True,
                env=env,
                timeout=timeout,
            )
        return result.stdout.strip()
    except subprocess.CalledProcessError as e:
        logging.error(f"Error executing command: {cmd}")
        logging.error(f"Error: {e}")
        logging.error(f"Output: {e.stderr}")
        return None
    except subprocess.TimeoutExpired:
        logging.error(f"Command timed out: {cmd}")
        return None
    except Exception as e:
        logging.error(f"Unexpected error executing: {cmd}")
        logging.error(f"Exception: {str(e)}")
        return None

def is_gdm_settings_installed():
    """Check if gdm-settings is installed"""
    try:
        result = subprocess.run(
            ["pacman", "-Qi", "gdm-settings"],
            text=True,
            capture_output=True,
            check=False,
        )
        if result.returncode == 0:
            return True
        if os.path.exists("/usr/bin/gdm-settings"):
            return True
        return False
    except Exception as e:
        logging.error(f"Error checking gdm-settings: {str(e)}")
        return False

def should_monitor_wallpaper(force=False):
    """Check if we should monitor wallpaper (gdm-settings not installed)"""
    global _last_monitor_check, _last_should_monitor

    now = time.monotonic()
    if (
        not force
        and _last_should_monitor is not None
        and now - _last_monitor_check < MONITOR_CHECK_INTERVAL
    ):
        return _last_should_monitor

    _last_monitor_check = now
    if is_gdm_settings_installed():
        _last_should_monitor = False
        return _last_should_monitor
    
    # Check if our theme files exist
    if not os.path.exists("/usr/share/gnome-shell/gnome-shell-theme.gresource.default"):
        logging.warning("BigCommunity: Default theme backup not found")
        _last_should_monitor = False
        return _last_should_monitor
    
    _last_should_monitor = True
    return _last_should_monitor

def get_session_info(session_id):
    """Get loginctl properties for a session"""
    output = run_command([
        'loginctl',
        'show-session',
        session_id,
        '-p', 'Name',
        '-p', 'User',
        '-p', 'Class',
        '-p', 'State',
        '-p', 'Active',
        '-p', 'Type',
        '-p', 'Seat',
        '-p', 'Remote',
    ])
    if not output:
        return {}

    info = {'Id': session_id}
    for line in output.splitlines():
        if '=' in line:
            key, value = line.split('=', 1)
            info[key] = value
    return info

def is_real_user_session(info, allow_remote=False):
    """Return True for a desktop user session, not GDM greeter/manager"""
    name = info.get('Name', '')
    if not name or name in ('gdm', 'gdm-greeter'):
        return False
    if name.startswith('gdm-'):
        return False
    if info.get('Class') != 'user':
        return False
    if not allow_remote and info.get('Remote') == 'yes':
        return False

    try:
        uid = int(info.get('User') or pwd.getpwnam(name).pw_uid)
    except (ValueError, KeyError):
        return False
    return uid >= 1000

def session_score(info):
    """Prefer the active graphical local session when more than one exists"""
    score = 0
    if info.get('Active') == 'yes':
        score += 20
    if info.get('State') in ('active', 'online'):
        score += 10
    if info.get('Seat'):
        score += 8
    if info.get('Type') in ('wayland', 'x11'):
        score += 6
    return score

def get_active_session():
    """Get the best real user session and ignore GDM greeter sessions"""
    try:
        for attempt in range(3):
            try:
                output = subprocess.run(['loginctl', 'list-sessions', '--no-legend'],
                                     check=True, text=True, capture_output=True).stdout.strip()

                candidates = []
                for line in output.splitlines():
                    parts = line.split()
                    if not parts:
                        continue
                    session_id = parts[0]
                    info = get_session_info(session_id)
                    if is_real_user_session(info):
                        candidates.append((session_score(info), session_id, info))

                if candidates:
                    candidates.sort(reverse=True, key=lambda item: item[0])
                    session_id = candidates[0][1]
                    logging.debug(f"Selected user session {session_id}: {candidates[0][2]}")
                    return session_id
                return None
            except subprocess.CalledProcessError as e:
                if attempt < 2:
                    logging.warning(f"loginctl error (attempt {attempt+1}/3): {e.stderr.strip()}")
                    time.sleep(2)
                else:
                    logging.error(f"Failed to get session after 3 attempts: {e.stderr.strip()}")
                    return None
    except Exception as e:
        logging.error(f"Error getting active session: {str(e)}")
        return None

def get_session_user(session_id):
    """Get user from session"""
    if not session_id:
        return None
    return run_command(['loginctl', 'show-session', session_id, '-p', 'Name', '--value'])

def get_session_display(session_id):
    """Get display from session"""
    if not session_id:
        return None
    display = run_command(['loginctl', 'show-session', session_id, '-p', 'Display', '--value'])
    return display if display else ":0"

def get_user_bus_address(user):
    """Get the standard per-user DBUS address if the bus exists"""
    try:
        bus_path = f"/run/user/{pwd.getpwnam(user).pw_uid}/bus"
        if os.path.exists(bus_path):
            return f"unix:path={bus_path}"
    except KeyError:
        pass
    return None

def get_dbus_address(user):
    """Get DBUS address for communication with user session"""
    if not user:
        return None
        
    try:
        pids = run_command(['pgrep', '-u', user, 'gnome-session'])
        pid = pids.splitlines()[0] if pids else None
        if not pid:
            return get_user_bus_address(user)
            
        environ_file = f"/proc/{pid}/environ"
        if not os.path.exists(environ_file):
            return get_user_bus_address(user)
            
        with open(environ_file, 'rb') as f:
            environ = f.read().split(b'\0')
            
        for var in environ:
            var_str = var.decode('utf-8', errors='ignore')
            if var_str.startswith('DBUS_SESSION_BUS_ADDRESS='):
                return var_str.split('=', 1)[1]
        return get_user_bus_address(user)
    except Exception as e:
        logging.error(f"Error getting DBUS address: {str(e)}")
        return get_user_bus_address(user)

def user_env_args(user, display, dbus_address):
    """Build environment arguments for commands run inside the user session."""
    env_args = []
    try:
        user_info = pwd.getpwnam(user)
        env_args.extend([
            f"HOME={user_info.pw_dir}",
            f"USER={user}",
            f"LOGNAME={user}",
            f"XDG_RUNTIME_DIR=/run/user/{user_info.pw_uid}",
        ])
    except KeyError:
        pass
    if display:
        env_args.append(f"DISPLAY={display}")
    if dbus_address:
        env_args.append(f"DBUS_SESSION_BUS_ADDRESS={dbus_address}")
    return env_args

def user_command_args(user, command, display=None, dbus_address=None):
    """Build a runuser command without opening an interactive shell."""
    return [
        'runuser',
        '-u',
        user,
        '--',
        'env',
        *user_env_args(user, display, dbus_address),
        *command,
    ]

def run_user_command(user, command, display=None, dbus_address=None, timeout=10):
    """Run a command in the user session without shell quoting."""
    return run_command(
        user_command_args(user, command, display, dbus_address),
        timeout=timeout,
    )

def start_user_process(user, command, display=None, dbus_address=None):
    """Start a long-running command in the user session."""
    try:
        return subprocess.Popen(
            user_command_args(user, command, display, dbus_address),
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        )
    except Exception as e:
        logging.warning(f"Failed to start user process {command}: {e}")
        return None

def get_user_wallpaper(user, display, dbus_address):
    """Get user's current wallpaper"""
    if not user or not display or not dbus_address:
        return None

    try:
        scheme = run_user_command(
            user,
            ['gsettings', 'get', 'org.gnome.desktop.interface', 'color-scheme'],
            display,
            dbus_address,
        )

        keys = list(BACKGROUND_KEYS)
        if scheme and 'prefer-dark' in scheme:
            keys.reverse()

        for key in keys:
            wallpaper_uri = run_user_command(
                user,
                ['dconf', 'read', key],
                display,
                dbus_address,
            )
            if wallpaper_uri and wallpaper_uri != "''":
                return wallpaper_uri
        return None
    except Exception as e:
        logging.error(f"Error getting wallpaper: {str(e)}")
        return None

def update_gdm_wallpaper(user, display, dbus_address, wallpaper_uri=None):
    """Call the updater while holding the shared theme lock."""
    lock_fd = acquire_lock(5)
    if lock_fd is None:
        logging.warning("Could not acquire lock for theme update")
        return False

    try:
        env = os.environ.copy()
        env.update({
            'COMM_WALLPAPER_USER': user,
            'COMM_WALLPAPER_DISPLAY': display,
            'COMM_WALLPAPER_DBUS_ADDRESS': dbus_address,
        })
        if wallpaper_uri:
            env['COMM_WALLPAPER_URI'] = wallpaper_uri
        result = run_command(['/usr/bin/comm-update-gdm-wallpaper'], env=env, timeout=120)
        if result is not None:
            logging.info("BigCommunity: GDM wallpaper updated successfully")
            return True
        return False
    finally:
        release_lock(lock_fd)

def stop_process(process):
    """Terminate a helper process without leaving a dconf watch behind."""
    if not process or process.poll() is not None:
        return
    process.terminate()
    try:
        process.wait(timeout=3)
    except subprocess.TimeoutExpired:
        process.kill()
        process.wait(timeout=3)

def monitor_session(session_id, user, display, dbus_address):
    """Monitor one graphical session using dconf watch with polling fallback."""
    logging.info(f"BigCommunity: Monitoring wallpaper for user {user}")
    watch = start_user_process(
        user,
        ['dconf', 'watch', BACKGROUND_PATH],
        display,
        dbus_address,
    )
    if watch:
        logging.info("BigCommunity: dconf wallpaper watcher active")
    else:
        logging.warning("BigCommunity: Falling back to wallpaper polling")

    old_wallpaper = None
    have_wallpaper = False
    next_session_check = 0
    next_poll = 0
    retry_wallpaper = None
    retry_after = 0

    try:
        while running and should_monitor_wallpaper():
            now = time.monotonic()

            if now >= next_session_check:
                if get_active_session() != session_id:
                    logging.info(f"Session {session_id} is no longer active")
                    if retry_wallpaper:
                        logging.info("Final wallpaper sync retry before leaving session")
                        update_gdm_wallpaper(user, display, dbus_address, retry_wallpaper)
                    break
                next_session_check = now + SESSION_CHECK_INTERVAL

            changed = not have_wallpaper
            if retry_wallpaper and now >= retry_after:
                changed = True

            if watch and watch.poll() is None and not changed:
                readable, _, _ = select.select([watch.stdout], [], [], 1)
                if readable:
                    line = watch.stdout.readline()
                    if line:
                        logging.debug(f"Wallpaper dconf change: {line.strip()}")
                        changed = True
                    else:
                        logging.warning("Wallpaper dconf watcher closed")
                        stop_process(watch)
                        watch = None
                        next_poll = 0
            elif watch and watch.poll() is not None:
                stderr = watch.stderr.read().strip() if watch.stderr else ""
                logging.warning(f"Wallpaper dconf watcher exited: {stderr}")
                watch = None
                next_poll = 0

            if not watch and not changed:
                if now >= next_poll:
                    changed = True
                    next_poll = now + POLL_FALLBACK_INTERVAL
                else:
                    time.sleep(1)
                    continue

            if not changed:
                continue

            # Let dconf settle when several keys change together.
            time.sleep(0.3)
            new_wallpaper = get_user_wallpaper(user, display, dbus_address)
            if not new_wallpaper:
                have_wallpaper = True
                continue

            if not have_wallpaper or new_wallpaper != old_wallpaper or retry_wallpaper == new_wallpaper:
                logging.info(f"BigCommunity: Wallpaper changed to: {new_wallpaper}")
                if update_gdm_wallpaper(user, display, dbus_address, new_wallpaper):
                    retry_wallpaper = None
                else:
                    retry_wallpaper = new_wallpaper
                    retry_after = time.monotonic() + POLL_FALLBACK_INTERVAL
                    logging.warning("GDM wallpaper update failed; will retry later")
                old_wallpaper = new_wallpaper
                have_wallpaper = True
    finally:
        stop_process(watch)

def main():
    """Main function to monitor wallpaper changes"""
    global running
    
    signal.signal(signal.SIGTERM, signal_handler)
    signal.signal(signal.SIGINT, signal_handler)
    
    if os.geteuid() != 0:
        logging.error("This script must be run as root")
        print("This script must be run as root")
        sys.exit(1)
    
    logging.info("BigCommunity wallpaper sync started")
    
    # Initial status check
    if should_monitor_wallpaper(force=True):
        logging.info("BigCommunity wallpaper sync active - monitoring enabled")
    else:
        logging.info("BigCommunity wallpaper sync in compatibility mode - gdm-settings detected")
    
    while running:
        try:
            # Check if we should continue monitoring
            if not should_monitor_wallpaper():
                logging.debug("Monitoring disabled - gdm-settings present")
                time.sleep(MONITOR_CHECK_INTERVAL)
                continue
            
            # Get active session
            session_id = get_active_session()
            if not session_id:
                logging.debug("No active session found")
                time.sleep(5)
                continue
            
            user = get_session_user(session_id)
            if not user:
                logging.debug(f"No user found for session {session_id}")
                time.sleep(5)
                continue
                
            display = get_session_display(session_id)
            dbus_address = get_dbus_address(user)
            if not dbus_address:
                logging.debug(f"Could not get DBUS address for user {user}")
                time.sleep(5)
                continue
            monitor_session(session_id, user, display, dbus_address)
                    
        except Exception as e:
            logging.error(f"Error in main loop: {str(e)}")
            
        time.sleep(5)
    
    logging.info("BigCommunity wallpaper sync stopped")

if __name__ == "__main__":
    main()
