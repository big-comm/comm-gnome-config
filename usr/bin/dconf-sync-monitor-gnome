#!/bin/bash

# dconf-sync-monitor-gnome - Monitor and sync dconf settings for GNOME
# Part of comm-gnome-config package

set -euo pipefail

DESKTOP_ENV="gnome"
DCONF_DIR="${HOME}/.config/dconf"
SETTINGS_FILE="${DCONF_DIR}/settings.${DESKTOP_ENV}"
LOG_FILE="/tmp/dconf-sync-${DESKTOP_ENV}.log"

# External tools (e.g. layout-switcher) create this lock to coordinate
# atomic writes to settings.gnome. While present, the watcher must not
# dump the live dconf — its output would clobber the clean settings.gnome
# the external tool is in the process of writing.
LOCK_FILE="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/dconf-sync-${DESKTOP_ENV}.lock"
LAYOUT_SWITCHER_HASH_FILE="${SETTINGS_FILE}.layout-switcher.sha256"

# After settings.gnome is written by an external tool, the file's mtime is
# fresh. The watcher's queued dconf events can arrive after the lock is
# released and overwrite it with live in-flight state. If the file is newer
# than this many seconds and was not written by this monitor, skip the save.
FRESH_FILE_SECONDS=10

# Ensure directory exists
mkdir -p "${DCONF_DIR}"

# Logging function
log_message() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [${DESKTOP_ENV}] $1" | tee -a "${LOG_FILE}"
}

# Check if dconf has valid settings (not reset to defaults)
is_dconf_valid() {
    local icon_theme=$(dconf read /org/gnome/desktop/interface/icon-theme 2>/dev/null || echo "")
    # If icon-theme is empty, 'default', or 'HighContrast', dconf may be in a reset state
    if [[ -z "$icon_theme" || "$icon_theme" == "'default'" || "$icon_theme" == "'HighContrast'" ]]; then
        return 1
    fi
    return 0
}

LAST_MONITOR_FILE_STAMP=""

settings_file_mtime() {
    stat -c %Y "${SETTINGS_FILE}" 2>/dev/null || echo 0
}

settings_file_stamp() {
    stat -c '%Y:%i:%s' "${SETTINGS_FILE}" 2>/dev/null || true
}

settings_file_age() {
    local mtime
    mtime=$(settings_file_mtime)
    echo "$(($(date +%s) - mtime))"
}

settings_file_is_fresh_external() {
    if [[ ! -s "${SETTINGS_FILE}" ]]; then
        return 1
    fi

    local age
    age=$(settings_file_age)
    if [ "${age}" -ge "${FRESH_FILE_SECONDS}" ]; then
        return 1
    fi

    local stamp
    stamp=$(settings_file_stamp)
    if [[ -z "${stamp}" || "${stamp}" == "${LAST_MONITOR_FILE_STAMP}" ]]; then
        return 1
    fi

    return 0
}

# Debounce mechanism - avoid saving too frequently
LAST_SAVE=0
DEBOUNCE_SECONDS=2
STARTED_AT=$(date +%s)
STARTUP_GRACE_SECONDS=20

in_startup_grace() {
    local current_time
    current_time=$(date +%s)
    local uptime=$((current_time - STARTED_AT))
    [ "${uptime}" -lt "${STARTUP_GRACE_SECONDS}" ]
}

save_settings() {
    local current_time=$(date +%s)
    local time_diff=$((current_time - LAST_SAVE))

    if [ ${time_diff} -lt ${DEBOUNCE_SECONDS} ]; then
        return
    fi

    # External tool is mid-apply; do not clobber its in-flight write.
    if [ -e "${LOCK_FILE}" ]; then
        log_message "Skipping save - lock file present (${LOCK_FILE})"
        return
    fi

    if settings_file_is_fresh_external; then
        local file_age
        file_age=$(settings_file_age)
        log_message "Skipping save - settings.gnome was externally updated ${file_age}s ago"
        LAST_SAVE=${current_time}
        return
    fi

    if in_startup_grace; then
        local uptime=$((current_time - STARTED_AT))
        log_message "Skipping save - startup grace (${uptime}s/${STARTUP_GRACE_SECONDS}s)"
        LAST_SAVE=${current_time}
        return
    fi

    # Verify dconf has valid settings before saving
    if ! is_dconf_valid; then
        local current_icon=$(dconf read /org/gnome/desktop/interface/icon-theme 2>/dev/null || echo "empty")
        log_message "Skipping save - dconf appears reset (icon-theme: $current_icon)"
        return
    fi

    log_message "Saving dconf settings to ${SETTINGS_FILE}"

    # Atomic write using temp file
    if dconf dump / > "${SETTINGS_FILE}.tmp" 2>/dev/null; then
        # Validate that dump is not empty (protection against forced shutdown corruption)
        if [[ ! -s "${SETTINGS_FILE}.tmp" ]]; then
            log_message "WARNING: dconf dump produced empty output, skipping save"
            rm -f "${SETTINGS_FILE}.tmp"
            return
        fi
        # Keep backup of current good settings before overwriting
        if [[ -s "${SETTINGS_FILE}" ]]; then
            cp -f "${SETTINGS_FILE}" "${SETTINGS_FILE}.bak"
        fi
        mv "${SETTINGS_FILE}.tmp" "${SETTINGS_FILE}"
        rm -f "${LAYOUT_SWITCHER_HASH_FILE}"
        sync "${SETTINGS_FILE}"
        LAST_MONITOR_FILE_STAMP=$(settings_file_stamp)
        LAST_SAVE=${current_time}
        log_message "Settings saved successfully"
    else
        log_message "ERROR: Failed to dump dconf settings"
        rm -f "${SETTINGS_FILE}.tmp"
    fi
}

# Main monitoring loop
log_message "Starting dconf monitor for ${DESKTOP_ENV}"
log_message "Settings file: ${SETTINGS_FILE}"

# Wait a moment for GNOME Shell to fully initialize before any saves
sleep 3

# Check initial state
if [ -e "${LOCK_FILE}" ]; then
    log_message "Initial save skipped - lock file present (external apply in progress)"
elif settings_file_is_fresh_external; then
    file_age=$(settings_file_age)
    log_message "Initial save skipped - settings.gnome is fresh (${file_age}s old)"
elif is_dconf_valid; then
    log_message "Initial dconf state is valid; waiting for user changes"
else
    current_icon=$(dconf read /org/gnome/desktop/interface/icon-theme 2>/dev/null || echo "empty")
    log_message "Initial dconf state appears reset (icon-theme: $current_icon), skipping initial save"
fi

# Monitor dconf changes
log_message "Monitoring dconf changes..."
dconf watch / | while read -r change; do
    log_message "Change detected: ${change}"
    save_settings
done

log_message "Monitor stopped"
