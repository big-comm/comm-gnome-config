#!/usr/bin/env python3

"""
BigCommunity GDM Wallpaper Updater
This script updates the GDM login screen to use the current user's wallpaper.
Optimized for BigCommunity distro with gdm-settings conflict detection.
"""

import os
import sys
import subprocess
import shutil
import tempfile
import logging
import pwd

# Configure logging
logging.basicConfig(
    filename='/var/log/gdm-wallpaper-updater.log',
    level=logging.INFO,
    format='%(asctime)s - BigCommunity - %(levelname)s - %(message)s'
)

# Shell theme gresource we patch with the GDM login wallpaper, plus the staging
# copy used when a live user session forbids touching the installed one.
GRESOURCE_LIVE = "/usr/share/gnome-shell/gnome-shell-theme.gresource"
GRESOURCE_PENDING = GRESOURCE_LIVE + ".pending"


def gnome_shell_running():
    """True when ANY gnome-shell is running — the GDM greeter OR a user session.

    Both the greeter (running as the 'gdm' user) and the logged-in user's
    session register /usr/share/gnome-shell/gnome-shell-theme.gresource, and
    swapping that file out from under EITHER breaks it: even an atomic
    os.replace() leaves the running shell unable to resolve its base stylesheet
    (St.Theme's default_stylesheet turns null), so the next shell-theme change
    throws "Argument file may not be null" and themes stop switching (from
    layout-switcher and gnome-tweaks alike). The only safe moment to install is
    while gdm.service is stopped and no shell is registered — which is exactly
    when comm-gdm-wallpaper-pending.service runs (Before=gdm).

    An earlier version only counted *user* shells (uid >= 1000). That installed
    during the session-startup window — while the greeter, or a just-spawning
    user shell, was registering the gresource — and corrupted it. Counting every
    gnome-shell closes that race.
    """
    try:
        out = subprocess.run(
            ["pgrep", "-x", "gnome-shell"],
            text=True, capture_output=True, check=False,
        ).stdout
        return bool(out.strip())
    except Exception as e:
        # Fail safe: assume a shell is up, so we stage rather than risk a
        # destructive in-session install.
        logging.error(f"Error checking for running gnome-shell: {e}")
        return True


def _atomic_install(src, dst):
    """Place src at dst atomically (temp in the same dir → real rename)."""
    fd, tmp = tempfile.mkstemp(dir=os.path.dirname(dst), prefix=".gstheme-", suffix=".tmp")
    os.close(fd)
    shutil.copy(src, tmp)
    os.chmod(tmp, 0o644)
    os.replace(tmp, dst)


def install_or_stage_gresource(src):
    """Install the rebuilt theme gresource, or stage it if a session is live.

    While any gnome-shell is running we must not touch GRESOURCE_LIVE at all
    (see gnome_shell_running). Instead we stage to GRESOURCE_PENDING and let
    comm-gdm-wallpaper-pending.service install it before the next GDM greeter —
    the only moment no shell is registered and the swap is safe. The user's
    *desktop* wallpaper is never affected by this; it only governs the GDM
    *login* wallpaper, which is just deferred to the next greeter.
    """
    if gnome_shell_running():
        _atomic_install(src, GRESOURCE_PENDING)
        logging.info(
            "BigCommunity: a gnome-shell is running — GDM login theme staged to "
            ".pending; it will be applied before the next greeter (running "
            "shell left untouched)"
        )
    else:
        _atomic_install(src, GRESOURCE_LIVE)
        try:
            os.remove(GRESOURCE_PENDING)
        except FileNotFoundError:
            pass
        logging.info("BigCommunity: GDM wallpaper theme successfully updated")


def apply_pending_gresource():
    """Install a previously staged gresource when it is safe to do so.

    Run by comm-gdm-wallpaper-pending.service, ordered Before=gdm.service, so it
    fires before the greeter and with no gnome-shell alive.
    """
    if os.geteuid() != 0:
        logging.error("apply-pending must run as root")
        return
    if not os.path.exists(GRESOURCE_PENDING):
        return
    if gnome_shell_running():
        logging.info("BigCommunity: pending GDM theme kept — a gnome-shell is still running")
        return
    try:
        _atomic_install(GRESOURCE_PENDING, GRESOURCE_LIVE)
        os.remove(GRESOURCE_PENDING)
        logging.info("BigCommunity: pending GDM wallpaper theme applied before greeter")
    except Exception as e:
        logging.error(f"Error applying pending GDM theme: {e}")


def run_command(cmd, shell=False):
    """Execute command and return output or None on error"""
    try:
        if shell:
            result = subprocess.run(cmd, shell=True, check=True, text=True, capture_output=True)
        else:
            result = subprocess.run(cmd, check=True, text=True, capture_output=True)
        return result.stdout.strip()
    except subprocess.CalledProcessError as e:
        logging.error(f"Error executing command: {cmd}")
        logging.error(f"Error: {e}")
        logging.error(f"Output: {e.stderr}")
        return None
    except Exception as e:
        logging.error(f"Unexpected error executing: {cmd}")
        logging.error(f"Exception: {str(e)}")
        return None

def is_gdm_settings_installed():
    """Check if gdm-settings is installed"""
    try:
        result = subprocess.run(
            ["pacman", "-Qi", "gdm-settings"],
            text=True,
            capture_output=True,
            check=False,
        )
        if result.returncode == 0:
            return True
        if os.path.exists("/usr/bin/gdm-settings"):
            return True
        return False
    except Exception as e:
        logging.error(f"Error checking gdm-settings: {str(e)}")
        return False

def get_session_info(session_id):
    """Get loginctl properties for a session"""
    output = run_command([
        'loginctl',
        'show-session',
        session_id,
        '-p', 'Name',
        '-p', 'User',
        '-p', 'Class',
        '-p', 'State',
        '-p', 'Active',
        '-p', 'Type',
        '-p', 'Seat',
        '-p', 'Remote',
    ])
    if not output:
        return {}

    info = {'Id': session_id}
    for line in output.splitlines():
        if '=' in line:
            key, value = line.split('=', 1)
            info[key] = value
    return info

def is_real_user_session(info, allow_remote=False):
    """Return True for a desktop user session, not GDM greeter/manager"""
    name = info.get('Name', '')
    if not name or name in ('gdm', 'gdm-greeter'):
        return False
    if name.startswith('gdm-'):
        return False
    if info.get('Class') != 'user':
        return False
    if not allow_remote and info.get('Remote') == 'yes':
        return False

    try:
        uid = int(info.get('User') or pwd.getpwnam(name).pw_uid)
    except (ValueError, KeyError):
        return False
    return uid >= 1000

def session_score(info):
    """Prefer the active graphical local session when more than one exists"""
    score = 0
    if info.get('Active') == 'yes':
        score += 20
    if info.get('State') in ('active', 'online'):
        score += 10
    if info.get('Seat'):
        score += 8
    if info.get('Type') in ('wayland', 'x11'):
        score += 6
    return score

def get_active_user_session(allow_remote=False):
    """Get the best real user session and ignore GDM greeter sessions"""
    sessions = run_command(['loginctl', 'list-sessions', '--no-legend'])
    if not sessions:
        return None, {}

    candidates = []
    for line in sessions.splitlines():
        parts = line.split()
        if not parts:
            continue
        session_id = parts[0]
        info = get_session_info(session_id)
        if is_real_user_session(info, allow_remote=allow_remote):
            candidates.append((session_score(info), session_id, info))

    if not candidates:
        return None, {}

    candidates.sort(reverse=True, key=lambda item: item[0])
    return candidates[0][1], candidates[0][2]

def restore_default_theme():
    """Restore the default GDM theme when gdm-settings is present"""
    try:
        default_theme = "/usr/share/gnome-shell/gnome-shell-theme.gresource.default"
        current_theme = "/usr/share/gnome-shell/gnome-shell-theme.gresource"
        
        if os.path.exists(default_theme):
            shutil.copy(default_theme, current_theme)
            os.chmod(current_theme, 0o644)
            logging.info("BigCommunity: Default GDM theme restored for gdm-settings compatibility")
            return True
        else:
            logging.warning("BigCommunity: Default theme backup not found")
            return False
    except Exception as e:
        logging.error(f"Error restoring default theme: {str(e)}")
        return False

def get_display_for_user(user):
    """Try to find the DISPLAY associated with a user session"""
    try:
        _, info = get_active_user_session()
        if info.get('Name') == user:
            display = run_command([
                'loginctl',
                'show-session',
                info.get('Id', ''),
                '-p',
                'Display',
                '--value',
            ])
            if display:
                return display
        return ":0"
    except Exception as e:
        logging.error(f"Failed to determine display from loginctl: {e}")
        return ":0"

def get_user_bus_address(user):
    """Get the standard per-user DBUS address if the bus exists"""
    try:
        bus_path = f"/run/user/{pwd.getpwnam(user).pw_uid}/bus"
        if os.path.exists(bus_path):
            return f"unix:path={bus_path}"
    except KeyError:
        pass
    return None

def get_dbus_address(user):
    """Get DBUS address for communication with user session"""
    if not user:
        return None

    try:
        pids = run_command(['pgrep', '-u', user, 'gnome-session'])
        pid = pids.splitlines()[0] if pids else None
        if not pid:
            return get_user_bus_address(user)

        environ_file = f"/proc/{pid}/environ"
        if not os.path.exists(environ_file):
            return get_user_bus_address(user)

        with open(environ_file, 'rb') as f:
            environ = f.read().split(b'\0')

        for var in environ:
            var_str = var.decode('utf-8', errors='ignore')
            if var_str.startswith('DBUS_SESSION_BUS_ADDRESS='):
                return var_str.split('=', 1)[1]
        return get_user_bus_address(user)
    except Exception as e:
        logging.error(f"Error getting DBUS address: {str(e)}")
        return get_user_bus_address(user)

def user_env_args(user, display, dbus_address):
    """Build environment arguments for commands run inside the user session."""
    env_args = []
    try:
        user_info = pwd.getpwnam(user)
        env_args.extend([
            f"HOME={user_info.pw_dir}",
            f"USER={user}",
            f"LOGNAME={user}",
            f"XDG_RUNTIME_DIR=/run/user/{user_info.pw_uid}",
        ])
    except KeyError:
        pass
    if display:
        env_args.append(f"DISPLAY={display}")
    if dbus_address:
        env_args.append(f"DBUS_SESSION_BUS_ADDRESS={dbus_address}")
    return env_args

def read_user_setting(user, display, dbus_address, command):
    """Run a settings command in the user's session"""
    return run_command([
        'runuser',
        '-u',
        user,
        '--',
        'env',
        *user_env_args(user, display, dbus_address),
        *command,
    ])

def get_user_wallpaper(user, display, dbus_address):
    """Get the wallpaper URI that matches the user's color scheme"""
    scheme = read_user_setting(
        user,
        display,
        dbus_address,
        ['gsettings', 'get', 'org.gnome.desktop.interface', 'color-scheme'],
    )

    keys = [
        '/org/gnome/desktop/background/picture-uri',
        '/org/gnome/desktop/background/picture-uri-dark',
    ]
    if scheme and 'prefer-dark' in scheme:
        keys.reverse()

    for key in keys:
        wallpaper = read_user_setting(user, display, dbus_address, ['dconf', 'read', key])
        if wallpaper and wallpaper != "''":
            return wallpaper.strip().strip("'")
    return None

def normalize_wallpaper_uri(wallpaper):
    """Normalize a wallpaper URI passed by dconf or the monitor service."""
    if not wallpaper:
        return None
    wallpaper = wallpaper.strip().strip("'").strip('"')
    if not wallpaper:
        return None
    return wallpaper

def main():
    # Boot-time hook (comm-gdm-wallpaper-pending.service, Before=gdm): install a
    # gresource that was staged while a user session was running.
    if "--apply-pending" in sys.argv[1:]:
        apply_pending_gresource()
        return

    logging.info("BigCommunity: Starting GDM wallpaper update")
    
    # Check if gdm-settings is installed
    if is_gdm_settings_installed():
        logging.info("BigCommunity: gdm-settings detected - applying default theme for compatibility")
        restore_default_theme()
        return
    
    # Check if running as root
    if os.geteuid() != 0:
        logging.error("This script must be run as root")
        print("This script must be run as root")
        sys.exit(1)
    
    # Create temporary directory
    temp_dir = tempfile.mkdtemp()
    try:
        # Get user session information
        current_user = os.environ.get('COMM_WALLPAPER_USER')
        display = os.environ.get('COMM_WALLPAPER_DISPLAY')
        dbus_address = os.environ.get('COMM_WALLPAPER_DBUS_ADDRESS')

        if not current_user:
            _, info = get_active_user_session()
            if not info:
                _, info = get_active_user_session(allow_remote=True)
            current_user = info.get('Name')

        if not current_user:
            logging.error("Could not determine current user")
            return

        if not display:
            display = get_display_for_user(current_user)
        if not display:
            logging.error("Could not determine display")
            return

        if not dbus_address:
            dbus_address = get_dbus_address(current_user)
        if not dbus_address:
            logging.error("Could not determine DBUS session address")
            return

        # Get wallpaper file. Prefer the value observed by wallpaper-monitor so
        # logout-time updates do not reread stale dconf state.
        wallpaper = normalize_wallpaper_uri(os.environ.get('COMM_WALLPAPER_URI'))
        if wallpaper:
            logging.info("BigCommunity: Using wallpaper provided by monitor")
        else:
            wallpaper = get_user_wallpaper(current_user, display, dbus_address)
        if not wallpaper:
            logging.error("Could not get wallpaper path")
            return
            
        # Remove file:// prefix
        wallpaper_file = wallpaper.replace("file://", "")
        logging.info(f"BigCommunity: Found wallpaper: {wallpaper_file}")
        
        # Copy and extract resources
        os.chdir(temp_dir)
        shutil.copy("/usr/share/gnome-shell/gnome-shell-theme.gresource", temp_dir)
        
        # List and extract resources
        resources = run_command("gresource list gnome-shell-theme.gresource", shell=True)
        if not resources:
            logging.error("Failed to list resources")
            return
            
        for resource in resources.splitlines():
            output_file = resource.replace("/org/gnome/shell/theme/", "")
            run_command(f"gresource extract gnome-shell-theme.gresource {resource} > {output_file}", shell=True)
        
        # Convert or copy wallpaper
        if wallpaper_file.lower().endswith('.avif'):
            run_command(f'magick "{wallpaper_file}" fundo.jpg', shell=True)
        else:
            shutil.copy(wallpaper_file, "fundo.jpg")

        # Apply Gaussian blur to wallpaper for frosted glass effect on GDM
        blur_result = run_command("magick fundo.jpg -blur 0x15 fundo.jpg", shell=True)
        if blur_result is None:
            logging.warning(
                "BigCommunity: Failed to apply blur to wallpaper, using original"
            )
        else:
            logging.info("BigCommunity: Blur applied to GDM wallpaper")

        # Create resource XML dynamically from extracted files
        extracted_files = [
            f
            for f in os.listdir(temp_dir)
            if f != "gnome-shell-theme.gresource"
            and f != "gnome-shell-theme.gresource.xml"
            and os.path.isfile(os.path.join(temp_dir, f))
        ]
        extracted_files.sort()

        file_entries = "\n    ".join(f"<file>{f}</file>" for f in extracted_files)
        xml_content = f"""<?xml version="1.0" encoding="UTF-8"?>
<gresources>
  <gresource prefix="/org/gnome/shell/theme">
    {file_entries}
  </gresource>
</gresources>"""
        
        with open("gnome-shell-theme.gresource.xml", "w") as f:
            f.write(xml_content)
        
        # Compile and install
        result = run_command("glib-compile-resources gnome-shell-theme.gresource.xml", shell=True)
        if result is None:
            logging.error("Failed to compile resources")
            return
        
        # Backup original if needed
        if not os.path.exists("/usr/share/gnome-shell/gnome-shell-theme.gresource.default"):
            if os.path.exists("/usr/share/gnome-shell/gnome-shell-theme.gresource"):
                shutil.copy("/usr/share/gnome-shell/gnome-shell-theme.gresource", 
                           "/usr/share/gnome-shell/gnome-shell-theme.gresource.default")
        
        # Save backup copy for package
        shutil.copy("gnome-shell-theme.gresource", "/usr/share/gnome-shell/gnome-shell-theme.gresource.big")
        
        # Install new theme only if gdm-settings is not present.
        #
        # Never swap the gresource under a RUNNING user gnome-shell. An in-place
        # shutil.copy() corrupts it mid-write, but even an atomic os.replace()
        # (new inode) is not enough on GNOME 50: the live session still loses its
        # base stylesheet and the next shell-theme change throws "Argument file
        # may not be null", so themes stop switching. install_or_stage_gresource
        # therefore stages to a .pending file while a session is alive (applied
        # before the next greeter by comm-gdm-wallpaper-pending.service) and
        # installs immediately only when no user session is running.
        if not is_gdm_settings_installed():
            install_or_stage_gresource("gnome-shell-theme.gresource")
        else:
            logging.info("BigCommunity: gdm-settings detected after processing - theme not applied")
        
    except Exception as e:
        logging.error(f"Error updating GDM theme: {str(e)}")
    finally:
        # Clean up
        shutil.rmtree(temp_dir, ignore_errors=True)

if __name__ == "__main__":
    main()
